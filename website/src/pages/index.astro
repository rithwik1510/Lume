---
import "../styles/fonts.css";
import "@xterm/xterm/css/xterm.css";
import "../styles/lume.css";
import { Image } from "astro:assets";
import Analytics from "@vercel/analytics/astro";
import appAgents from "../assets/app-agents.png";

const title = "Lume — a command center for your coding agents";
const description =
  "Smooth tiled terminals, a markdown viewer, and a file sidebar in one window — built to host a fleet of coding agents (Claude Code, Codex, Gemini) without breaking visually.";
const canonical = new URL(Astro.url.pathname, Astro.site);
const ogImage = new URL("/og.png", Astro.site);
---

<!doctype html>
<html lang="en" data-theme="cobalt" data-font-pair="modern" data-motion="smooth">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <meta name="theme-color" content="#0a0a0a" />
  <meta name="color-scheme" content="dark" />

  <!-- Open Graph / Twitter -->
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content="Lume" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonical} />
  <meta property="og:image" content={ogImage} />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />
</head>
<body>

<!-- ============================ NAV (titlebar) ============================ -->
<header class="nav">
  <div class="nav-in">
    <a class="brand" href="#top" aria-label="Lume home">
      <span class="mark"></span>
      <span class="name">Lume</span>
      <span class="ver mono">v0.1.0-beta.9</span>
    </a>
    <nav class="nav-links">
      <a href="#smoothness">Smoothness</a>
      <a href="#split">Tiling</a>
      <a href="#markdown">Markdown</a>
      <a href="#keyboard">Keyboard</a>
      <a href="#themes">Themes</a>
    </nav>
    <div class="nav-cta">
      <button class="pal-chip mono" id="palHint" title="Command palette" aria-label="Open command palette">
        <span class="kbd">Ctrl</span><span class="kbd">K</span>
      </button>
      <a class="nav-gh" href="https://github.com/rithwik1510/Workflow" target="_blank" rel="noopener">
        <svg class="ic" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2C6.48 2 2 6.58 2 12.25c0 4.53 2.87 8.37 6.84 9.73.5.1.68-.22.68-.49 0-.24-.01-.88-.01-1.73-2.78.62-3.37-1.37-3.37-1.37-.46-1.18-1.11-1.49-1.11-1.49-.91-.64.07-.62.07-.62 1 .07 1.53 1.06 1.53 1.06.89 1.56 2.34 1.11 2.91.85.09-.66.35-1.11.63-1.37-2.22-.26-4.55-1.14-4.55-5.06 0-1.12.39-2.03 1.03-2.75-.1-.26-.45-1.3.1-2.71 0 0 .84-.28 2.75 1.05A9.36 9.36 0 0 1 12 6.86c.85 0 1.71.12 2.51.34 1.91-1.33 2.75-1.05 2.75-1.05.55 1.41.2 2.45.1 2.71.64.72 1.03 1.63 1.03 2.75 0 3.93-2.34 4.79-4.57 5.05.36.32.68.94.68 1.9 0 1.37-.01 2.48-.01 2.82 0 .27.18.6.69.49A10.02 10.02 0 0 0 22 12.25C22 6.58 17.52 2 12 2Z"/></svg>
        GitHub
      </a>
    </div>
  </div>
</header>

<!-- ============================ HERO ============================ -->
<main id="top">
<section class="hero">
  <canvas id="constellation" aria-hidden="true"></canvas>
  <div class="hero-in">
    <span class="eyebrow rise" data-rise><span data-scramble="Tiled terminals · markdown · one window">Tiled terminals · markdown · one window</span></span>
    <h1 data-words>A command center for a<br/>fleet of <span class="accent">coding agents</span>.</h1>
    <p class="sub rise" data-rise>
      Claude Code, Codex, Gemini — tiled in one window, smooth enough to forget they're running.
    </p>
    <div class="hero-cta rise" data-rise>
      <a class="btn btn-primary" href="/download">
        <svg class="ic" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 3v12m0 0l-4-4m4 4l4-4"/><path d="M5 21h14"/></svg>
        Download for Windows
      </a>
      <a class="btn btn-ghost" href="https://github.com/rithwik1510/Workflow" target="_blank" rel="noopener">View on GitHub</a>
    </div>
    <div class="hero-meta rise" data-rise>
      <span><b>MIT</b> · open source</span>
      <span class="sep">/</span>
      <span>Windows first</span>
      <span class="sep">/</span>
      <span>macOS &amp; Linux soon</span>
    </div>
  </div>

  <!-- product window — static mock that hydrates into REAL xterm.js terminals -->
  <div class="stage rise" data-rise>
    <div class="win">
      <div class="titlebar">
        <div class="tb-left">
          <span class="tb-mark"></span>
          <span class="tb-name">Lume</span>
          <span class="tb-path">~/projects/auth</span>
        </div>
        <div class="tb-spacer"></div>
        <div class="tb-icons">
          <span class="tb-ic" title="Sidebar"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="16" rx="2"/><line x1="9" y1="4" x2="9" y2="20"/></svg></span>
          <span class="tb-ic" title="Split"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="16" rx="2"/><line x1="12" y1="4" x2="12" y2="20"/></svg></span>
          <span class="tb-ic" title="Markdown editor"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H6a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-5"/><path d="M18.5 2.5a2.12 2.12 0 0 1 3 3L12 15l-4 1 1-4z"/></svg></span>
          <span class="tb-ic" title="Settings"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg></span>
        </div>
        <div class="tb-win">
          <span class="tb-ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"><line x1="5" y1="12" x2="19" y2="12"/></svg></span>
          <span class="tb-ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><rect x="5" y="5" width="14" height="14" rx="1.5"/></svg></span>
          <span class="tb-ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"><line x1="6" y1="6" x2="18" y2="18"/><line x1="18" y1="6" x2="6" y2="18"/></svg></span>
        </div>
      </div>

      <div class="win-body">
        <!-- sidebar -->
        <aside class="side">
          <div class="side-hd">
            <span class="filter"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="7"/><line x1="20" y1="20" x2="16.65" y2="16.65"/></svg>filter</span>
            <svg class="plus" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
          </div>
          <div class="tree">
            <div class="row dir"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>auth</div>
            <div class="row dir ind"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>src</div>
            <div class="row ind2"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>session.ts</div>
            <div class="row ind2"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>tokenStore.ts</div>
            <div class="row md ind active"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="8" y1="13" x2="14" y2="13"/><line x1="8" y1="17" x2="13" y2="17"/></svg>PLAN.md</div>
            <div class="row dir ind" style="opacity:.55"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" style="transform:rotate(-90deg)"><polyline points="6 9 12 15 18 9"/></svg>node_modules</div>
            <div class="row ind"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>README.md</div>
          </div>
        </aside>

        <!-- panes (the .term mounts become live xterm.js on first view) -->
        <div class="panes">
          <div class="pane tall focused">
            <div class="pane-hd"><span class="dot run cl"></span><span class="agn cl">✻ Claude Code</span><span class="cw">wsl · ~/projects/auth</span></div>
            <div class="term" data-term="cl">
<div class="ln"><span class="cl">✻</span> <span class="c">Claude Code</span> <span class="dim">· opus 4.8</span></div>
<div class="ln"><span class="cl">&gt;</span> wire the session refresh flow</div>
<div class="ln">&nbsp;</div>
<div class="ln"><span class="cl">⏺</span> <span class="c">Update</span><span class="dim">(src/auth/session.ts)</span></div>
<div class="ln"><span class="dim">  ⎿</span> <span class="ok">+ import &#123; tokenStore &#125; from "./tokenStore"</span></div>
<div class="ln"><span class="er">     - localStorage.getItem("session")</span></div>
            </div>
          </div>
          <div class="pane">
            <div class="pane-hd"><span class="dot run cx"></span><span class="agn cx">▌ Codex</span><span class="cw">pwsh</span></div>
            <div class="term" data-term="cx">
<div class="ln"><span class="cx">›</span> add the migration script</div>
<div class="ln"><span class="cx">•</span> Editing <span class="c">migrate.ts</span></div>
<div class="ln"><span class="cx">•</span> npm run build</div>
<div class="ln"><span class="ok">  ✓ built in 3.2s</span></div>
            </div>
          </div>
          <div class="pane">
            <div class="pane-hd"><span class="dot run gm"></span><span class="agn gm">✦ Gemini</span><span class="cw">wsl</span></div>
            <div class="term" data-term="gm">
<div class="ln"><span class="gm">✦</span> review the diff</div>
<div class="ln"><span class="dim">  3 files · </span><span class="ok">+84</span> <span class="er">−12</span></div>
<div class="ln"><span class="gm">✦</span> thinking…</div>
            </div>
          </div>
        </div>
      </div>

      <div class="statusbar">
        <span class="seg"><span>pwsh</span><span class="dim">·</span><span>~/projects/auth</span></span>
        <span class="seg"><span>3 panes</span><span class="dim">·</span><span class="run-dot"></span><span>3 agents live</span></span>
      </div>
    </div>
  </div>
</section>

<hr class="divider" />

<!-- ====================== 01 · SMOOTHNESS ====================== -->
<section class="sec" id="smoothness">
  <div class="wrap">
    <div class="sec-head">
      <span class="eyebrow"><span class="idx">01</span> <span data-scramble="Smoothness">Smoothness</span></span>
      <h2 data-words>It doesn't tear under load.</h2>
      <p class="lead">
        Bytes stream Rust → renderer, never through the UI state. Flood every pane — typing still lands first.
      </p>
    </div>
    <figure class="shotfig rise" data-rise style="margin-bottom:44px">
      <div class="shot"><Image src={appAgents} alt="Lume running four tiled Claude Code and OpenAI Codex agent sessions at once" loading="lazy" /></div>
      <figcaption class="shotcap"><span class="pulse"></span>The real app, untouched — four agents live at once, <b>auto mode on</b>, not a dropped frame.</figcaption>
    </figure>

    <div class="feat-grid">
      <div class="feat wide">
        <div class="ftop">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2 3 14h7l-1 8 10-12h-7l1-8z"/></svg>
          <span class="ftag">Acceptance test · four concurrent agents</span>
        </div>
        <h3>Built to pass the 2am test.</h3>
        <p>Three agents streaming, a release build, you typing through all of it — at once. No tearing.</p>
        <div class="feat-body">
          <div class="stats">
            <div class="stat"><div class="n">&lt;30<span class="u">ms</span></div><div class="l">typing latency</div><div class="spark" data-spark="8,7,7,8,7,8,8,7"></div></div>
            <div class="stat"><div class="n">32<span class="u">ms</span></div><div class="l">ipc batch window</div><div class="spark" data-spark="3,5,3,6,4,5,3,4"></div></div>
            <div class="stat"><div class="n">&lt;500<span class="u">MB</span></div><div class="l">memory, 4 panes</div><div class="spark" data-spark="2,3,4,4,5,5,5,5"></div></div>
            <div class="stat"><div class="n">&lt;2<span class="u">s</span></div><div class="l">cold start</div><div class="spark" data-spark="8,5,3,2,2,2,2,2"></div></div>
          </div>
        </div>
      </div>
      <div class="feat">
        <div class="ftop">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/></svg>
          <span class="ftag">Motion</span>
        </div>
        <h3>One curve, everywhere.</h3>
        <p>Every motion on the same ease-out. <span class="mono">cubic-bezier(.16, 1, .3, 1)</span> — fast in, long settle. This page runs on it too.</p>
      </div>
      <div class="feat">
        <div class="ftop">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/></svg>
          <span class="ftag">Renderer</span>
        </div>
        <h3>WebGL terminals, real PTYs.</h3>
        <p>xterm.js on WebGL, fed by <span class="mono">portable-pty</span>. 8&nbsp;MB ring buffer per pane.</p>
      </div>
    </div>
  </div>
</section>

<hr class="divider" />

<!-- ====================== 02 · SPLIT — scroll centerpiece ====================== -->
<section class="split-sec" id="split">
  <div class="split-track" id="splitTrack">
    <div class="split-pin">
      <div class="split-stage">
        <div class="split-text">
          <span class="eyebrow"><span class="idx">02</span> <span data-scramble="Tiling">Tiling</span></span>
          <h2 data-words>Split without the seams.</h2>
          <p class="lead">One pane becomes many. Every pane keeps streaming; nothing reflows with a jolt. Scroll — you're driving.</p>
          <div class="split-steps">
            <div class="split-step" data-step="0"><span class="k">Ctrl+Alt+→</span><span>split right</span></div>
            <div class="split-step" data-step="1"><span class="k">Ctrl+Alt+↓</span><span>split down</span></div>
          </div>
        </div>
        <div class="split-window">
          <div class="titlebar">
            <div class="tb-left"><span class="tb-mark"></span><span class="tb-name">Lume</span><span class="tb-path">~/projects/auth</span></div>
            <div class="tb-spacer"></div>
            <div class="tb-win">
              <span class="tb-ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"><line x1="5" y1="12" x2="19" y2="12"/></svg></span>
              <span class="tb-ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><rect x="5" y="5" width="14" height="14" rx="1.5"/></svg></span>
              <span class="tb-ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"><line x1="6" y1="6" x2="18" y2="18"/><line x1="18" y1="6" x2="6" y2="18"/></svg></span>
            </div>
          </div>
          <div class="split-panes" id="splitPanes">
            <div class="sp focused" data-sp="0">
              <div class="pane-hd"><span class="dot run cl"></span><span class="agn cl">✻ Claude Code</span><span class="cw">~/auth</span></div>
              <div class="term">
<div class="ln"><span class="cl">✻</span> wire up the refresh flow</div>
<div class="ln"><span class="cl">⏺</span> <span class="c">Update</span><span class="dim">(tokenStore.ts)</span></div>
<div class="ln"><span class="ok">  + async refresh()</span></div>
              </div>
            </div>
            <div class="sp" data-sp="1">
              <div class="pane-hd"><span class="dot run cx"></span><span class="agn cx">▌ Codex</span><span class="cw">build</span></div>
              <div class="term">
<div class="ln"><span class="cx">›</span> npm run dev</div>
<div class="ln"><span class="dim">  ➜ local: 5173</span></div>
<div class="ln"><span class="ok">  ✓ ready in 240ms</span></div>
              </div>
            </div>
            <div class="sp" data-sp="2">
              <div class="pane-hd"><span class="dot run gm"></span><span class="agn gm">✦ Gemini</span><span class="cw">~/auth</span></div>
              <div class="term">
<div class="ln"><span class="gm">✦</span> review the changes</div>
<div class="ln"><span class="dim">  3 files · </span><span class="ok">+84</span> <span class="er">−12</span></div>
<div class="ln"><span class="gm">✦</span> <span class="caret"></span></div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<hr class="divider" />

<!-- ====================== 03 · MARKDOWN — live render ====================== -->
<section class="sec" id="markdown">
  <div class="wrap">
    <div class="sec-head">
      <span class="eyebrow"><span class="idx">03</span> <span data-scramble="Markdown">Markdown</span></span>
      <h2 data-words>Read what they write.</h2>
      <p class="lead">Agents think in markdown. Lume renders it beside your panes — watch a plan take shape as it's written, then watch it get done.</p>
    </div>

    <div class="mdl rise" data-rise id="mdLive">
      <div class="mdl-hd">
        <span class="mdh-file"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="8" y1="13" x2="14" y2="13"/><line x1="8" y1="17" x2="13" y2="17"/></svg>PLAN.md</span>
        <span class="mdl-status mono" id="mdStatus">agent writing…</span>
        <span class="mdh-sp"></span>
        <button class="pen" id="mdReplay" title="Replay">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 2.13-9.36L1 10"/></svg>
        </button>
      </div>
      <div class="mdl-body">
        <div class="mdl-col">
          <div class="mdl-lab mono">edit · raw</div>
          <div class="md-src" id="mdSrc"></div>
        </div>
        <div class="mdl-col mdl-view">
          <div class="mdl-lab mono">view · rendered</div>
          <div class="md-view" id="mdView"></div>
        </div>
      </div>
    </div>
    <div class="themes-note" style="margin-top:20px"><span class="pulse"></span>In the app: Ctrl+Click any file path to open it · Ctrl+E to edit · Ctrl+Shift+M for the Quick Viewer.</div>
  </div>
</section>

<hr class="divider" />

<!-- ====================== 04 · KEYBOARD — live shortcuts ====================== -->
<section class="sec" id="keyboard">
  <div class="wrap">
    <div class="sec-head">
      <span class="eyebrow"><span class="idx">04</span> <span data-scramble="Keyboard-first">Keyboard-first</span></span>
      <h2 data-words>Your hands never leave home row.</h2>
      <p class="lead">Every action has a key. Rebind any of them in <span class="mono">config.toml</span>. The window on the right obeys them — try it.</p>
    </div>

    <div class="kb-grid">
      <div class="keys kb-keys">
        <div class="keyrow"><span class="act">Split right / up / down</span><span class="combo"><span class="kbd">Ctrl</span><span class="kbd">Alt</span><span class="kbd">→</span></span></div>
