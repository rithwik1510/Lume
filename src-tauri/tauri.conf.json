{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Lume",
  "version": "0.1.0-beta.1",
  "identifier": "com.posan.lume",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Lume",
        "width": 1280,
        "height": 800,
        "minWidth": 640,
        "minHeight": 400,
        "decorations": false,
        "fullscreen": false,
        "resizable": true,
        "backgroundColor": "#0a0a0a"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "createUpdaterArtifacts": true,
    "publisher": "Posan",
    "category": "DeveloperTool",
    "shortDescription": "Smooth tiled terminals + markdown for AI coding agents",
    "longDescription": "Lume hosts multiple AI coding agents in parallel across smooth tiled terminal panes, with a markdown editor and a localhost preview — one workstation for agent-driven development.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  }
}
