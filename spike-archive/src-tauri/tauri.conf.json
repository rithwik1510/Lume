{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Workstation Spike",
  "version": "0.0.1",
  "identifier": "com.posan.workstation.spike",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Workstation Spike",
        "width": 1200,
        "height": 800,
        "minWidth": 640,
        "minHeight": 400,
        "decorations": true,
        "fullscreen": false,
        "resizable": true,
        "backgroundColor": "#0a0a0a"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all",
    "icon": [
      "icons/icon.png"
    ]
  }
}
